FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      T;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
// Mass concentration (kg/m^3); x1e9 -> ug/m^3 for reporting.
// NOTE: the 'streets' source patch is NOT listed here -- it is carved from
// Terrain post-mesh by createPatch (which adds a streets entry to every field,
// inheriting Terrain's zeroGradient), and set_emissions.py then rewrites that
// entry to the per-segment fixedGradient. Authoring T to match the 4 real mesh
// patches keeps createPatch happy.

dimensions      [1 -3 0 0 0 0 0];

internalField   uniform 0;

boundaryField
{
    inletOutlet
    {
        type            inletOutlet;
        inletValue      uniform 0;
        value           uniform 0;
    }

    top         { type symmetry; }

    Terrain     { type zeroGradient; }
    Buildings   { type zeroGradient; }
}


