FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fvSchemes;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

ddtSchemes
{
    default         steadyState;        // frozen flow + steady source
}

gradSchemes
{
    default         Gauss linear;
}

divSchemes
{
    default         none;
    // First-order upwind: unconditionally bounded and monotonically convergent
    // in steadyState, so the emission/outlet balance closes cleanly. Swap to
    // 'Gauss limitedLinear 1' for accuracy once the chain is validated.
    div(phi,T)      bounded Gauss upwind;
}

laplacianSchemes
{
    default         Gauss linear corrected;
}

interpolationSchemes
{
    default         linear;
}

snGradSchemes
{
    default         corrected;
}


