FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 -1 0 0 0 0];

// Spatially-uniform horizontal wind (the provided reference wind is a single
// (u,v) per hour). Set per hour by the orchestration (see marker below).
internalField   uniform (1.953141 -1.420984 0);

boundaryField
{
    // Single all-round cylindrical boundary. The hourly wind arrives from a
    // DIFFERENT direction each hour, so this patch must accept inflow AND outflow
    // on any face. freestreamVelocity = fixedValue (=freestreamValue) on faces
    // where flow enters, zeroGradient where it leaves -- chosen per face from the
    // flux. One fixed mesh then handles every hourly wind direction, no remeshing.
    inletOutlet
    {
        type            freestreamVelocity;
        freestreamValue uniform (1.953141 -1.420984 0);   // HOURLY WIND (u v 0) <-- set per hour
    }

    top
    {
        type            symmetry;            // blockMesh 'symmetry top'
    }

    Terrain
    {
        type            noSlip;
    }

    Buildings
    {
        type            noSlip;
    }

    bottom
    {
        type            noSlip;
    }
}


