FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      nut;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -1 0 0 0 0];

internalField   uniform 0;

boundaryField
{
    inlet       { type calculated; value uniform 0; }
    outlet      { type calculated; value uniform 0; }
    top         { type slip; }

    // Standard (smooth) wall function on ground, streets and buildings.
    // Works on every OpenFOAM build (no extra library needed).
    //
    // To use atmospheric ROUGH walls instead (ESI/openfoam.com v2312+ only),
    // add to system/controlDict:   libs ("libatmosphericModels.so");
    // and replace the ground/street blocks with, e.g.:
    //     lowerWall { type nutkAtmRoughWallFunction; z0 uniform 0.3; value uniform 0; }
    lowerWall   { type nutkWallFunction; value uniform 0; }
    street1     { type nutkWallFunction; value uniform 0; }
    street2     { type nutkWallFunction; value uniform 0; }

    street3     { type nutkWallFunction; value uniform 0; }
    buildings   { type nutkWallFunction; value uniform 0; }

    frontAndBack { type empty; }
}


