#!/bin/bash
# Clean all mesh artefacts generated by runallgeo.sh, returning the case to
# its pre-run state.  Preserves: system/ (source dicts), 0/, geo/, constant/
# transport+turbulence properties, and the savedMesh/ folder unless -all is given.
#
# Usage:
#   ./Allclean           — remove mesh artefacts, keep savedMesh/
#   ./Allclean -all      — also wipe savedMesh/
#   ./Allclean -dry-run  — print what would be removed without deleting

set -euo pipefail

DRY=0
WIPE_SAVED=0
for arg in "$@"; do
    case "$arg" in
        -all)     WIPE_SAVED=1 ;;
        -dry-run) DRY=1 ;;
        *) echo "Unknown option: $arg" >&2; exit 1 ;;
    esac
done

remove() {
    for target in "$@"; do
        if [ -e "$target" ] || [ -L "$target" ]; then
            if [ "$DRY" -eq 1 ]; then
                echo "  [dry] rm -rf $target"
            else
                echo "  removing $target"
                rm -rf "$target"
            fi
        fi
    done
}

cd "$(dirname "$0")"
echo "=== Allclean: flowCase mesh ==="

# ---- snappyHexMesh time directories (1 = castellated, 2 = snapped) ----------
echo "-- snappyHexMesh time dirs --"
remove 1 2

# ---- decomposePar / reconstructPar artefacts --------------------------------
echo "-- parallel decomposition --"
remove processor*

# ---- blockMesh output (polyMesh rebuilt each run) ---------------------------
echo "-- polyMesh --"
remove constant/polyMesh

# ---- surface feature extraction output (.eMesh files) -----------------------
echo "-- surface features (.eMesh) --"
remove constant/triSurface/*.eMesh 2>/dev/null || true

# ---- triSurface copies (rsync'd from geo/ by runallgeo.sh) ------------------
echo "-- triSurface OBJ copies --"
remove constant/triSurface/Mesh_Buildings.obj \
       constant/triSurface/Mesh_Terrain.obj

# ---- generated blockMeshDict (produced by m4 from blockMeshDict.m4) ---------
echo "-- generated blockMeshDict --"
remove system/blockMeshDict

# ---- log files --------------------------------------------------------------
echo "-- logs --"
remove logs

# ---- savedMesh (only with -all) ---------------------------------------------
if [ "$WIPE_SAVED" -eq 1 ]; then
    echo "-- savedMesh (-all flag set) --"
    remove savedMesh
fi

echo "=== done ==="
