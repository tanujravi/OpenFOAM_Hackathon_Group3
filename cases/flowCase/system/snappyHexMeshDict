FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      snappyHexMeshDict;
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
/*----------------- Refinement-box envelope (recentred frame) -------------------*/
// Sized to the ROI buildings (X[-1523,1659] Y[-1244,1091] Z[15,176]) + buffer.
x_min  -1750;
y_min  -1450;
z_min  -5;
x_max   1850;
y_max   1300;
z_max   220.0;

// Tight city box: covers the ROI buildings footprint + 200 m margin.
// Used for intermediate (level 3) refinement so the city gets ~17 m cells
// without forcing that resolution onto the whole 6.3 km terrain.
cx_min -1750;
cy_min -1450;
cz_min    -5;
cx_max  1850;
cy_max  1300;
cz_max   250.0;

K #calc "($z_max - $z_min)/$z_max";
F 0.3;

// box1 (closer, finer)
x1_min #calc "$x_min - $K*$z_max";
x1_max #calc "$x_max + $K*$z_max";
y1_min #calc "$y_min - $K*$z_max";
y1_max #calc "$y_max + $K*$z_max";
z1_min $z_min;
z1_max #calc "$z_max + $F*$K*$z_max";

// box2 (wider, coarser)
x2_min #calc "$x_min - 2*$K*$z_max";
x2_max #calc "$x_max + 2*$K*$z_max";
y2_min #calc "$y_min - 2*$K*$z_max";
y2_max #calc "$y_max + 2*$K*$z_max";
z2_min $z_min;
z2_max #calc "$z_max + 1.2*$K*$z_max";

castellatedMesh true;
snap            true;
addLayers       false;


geometry
{
    box1
    {
        type searchableBox;
        min ($x1_min $y1_min $z1_min);
        max ($x1_max $y1_max $z1_max);
    }

    box2
    {
        type searchableBox;
        min ($x2_min $y2_min $z2_min);
        max ($x2_max $y2_max $z2_max);
    }

    // Tight city box: intermediate refinement zone around the ROI buildings.
    cityBox
    {
        type searchableBox;
        min ($cx_min $cy_min $cz_min);
        max ($cx_max $cy_max $cz_max);
    }

    Mesh_Buildings
    {
        file "Mesh_Buildings.obj";
        type triSurfaceMesh;
        regions
        {
            Buildings { name Buildings; }
        }
    }

    Mesh_Terrain
    {
        file "Mesh_Terrain.obj";
        type triSurfaceMesh;
        regions
        {
            Terrain { name Terrain; }
        }
    }
    // Mesh_Water / Mesh_Vegetation removed: no water surface is provided, and the
    // canopy is modelled as a porous zone (not a wall) in a later step.
}


castellatedMeshControls
{
    maxLocalCells 20000000;
    maxGlobalCells 200000000;
    minRefinementCells 0;
    maxLoadUnbalance 0.10;
    nCellsBetweenLevels 4;

    features
    (
        {
            file "Mesh_Buildings.eMesh";
            level 6;   // match the building surface max level
        }
    );

    refinementSurfaces
    {
        Mesh_Buildings
        {
            level (0 0);
            regions
            {
                Buildings
                {
                    // Level 6 (~2 m cells) on building walls; edge features also at 6.
                    level (5 6);
                    patchInfo { type wall; }
                }
            }
        }

        Mesh_Terrain
        {
            level (0 0);
            regions
            {
                Terrain
                {
                    // Far-field terrain at level 2 (~33 m cells) — the cityBox
                    // refinement region and distance rules bring it to level 3-4
                    // inside the ROI without blowing up cell count over 6.3 km.
                    level (2 2);
                    patchInfo { type wall; }
                }
            }
        }
    }

    resolveFeatureAngle 30;

    refinementRegions
    {
        // Far-field annular ring: level 1 (~67 m) — coarse, just captures bulk flow.
        box2
        {
            mode inside;
            levels ((1E15 1));
        }

        // Intermediate ring around the city: level 2 (~33 m).
        box1
        {
            mode inside;
            levels ((1E15 2));
        }

        // Tight city box: level 3 (~17 m).  Gives decent resolution on streets and
        // terrain inside the ROI without the level-4 blanket that was on all terrain.
        cityBox
        {
            mode inside;
            levels ((1E15 3));
        }

        // Buildings: graduated distance refinement — finest very close (level 6, ~2 m),
        // then stepping back to level 3 at ~50 m to match the city-box background.
        Mesh_Buildings
        {
            mode distance;
            levels ((2.0 6) (8.0 5) (20.0 4) (50.0 3));
        }

        // Terrain: only needs moderate near-surface refinement because the city-box
        // and building distance rules already cover the ROI ground area.
        Mesh_Terrain
        {
            mode distance;
            levels ((3.0 3) (12.0 2));
        }
    }

    // Air point: above the highest terrain (470 m), inside the cylinder (r=3000),
    // well below the domain top (~1870 m).
    locationInMesh (0 0 800);
    allowFreeStandingZoneFaces true;
}

snapControls
{
    nSmoothPatch 5;
    tolerance 4.0;
    nSolveIter 50;
    nRelaxIter 15;
    nFeatureSnapIter 15;
    implicitFeatureSnap false;
    explicitFeatureSnap true;
    multiRegionFeatureSnap false;
}

addLayersControls
{
    relativeSizes true;
    expansionRatio 1.2;
    firstLayerThickness 0.4;
    minThickness 0.4;
    layers{}
    nGrow 0;
    featureAngle 130;
    maxFaceThicknessRatio 0.5;
    nSmoothSurfaceNormals 1;
    nSmoothThickness 10;
    minMedialAxisAngle 90;
    maxThicknessToMedialRatio 0.3;
    nSmoothNormals 3;
    slipFeatureAngle 30;
    nRelaxIter 5;
    nBufferCellsNoExtrude 0;
    nLayerIter 50;
    nRelaxedIter 20;
}

meshQualityControls
{
    maxNonOrtho 65;
    maxBoundarySkewness 5;
    maxInternalSkewness 4;
    maxConcave 80;
    minVol 1e-13;
    minTetQuality 1e-30;
    minArea -1;
    minTwist 0.05;
    minDeterminant 0.001;
    minFaceWeight 0.05;
    minVolRatio 0.01;
    minTriangleTwist -1;
    minVolCollapseRatio 0.5;
    nSmoothScale 4;
    errorReduction 0.75;
    relaxed
    {
        maxNonOrtho 75;
    }
}

mergeTolerance 1e-6;

// ************************************************************************* //
