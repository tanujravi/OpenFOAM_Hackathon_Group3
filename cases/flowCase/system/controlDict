FoamFile
{
    version	2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     simpleFoam;

startFrom       latestTime;

startTime       0;

stopAt          endTime;

endTime		2000;

deltaT          1;

writeControl    timeStep;

writeInterval   500;    // intermediate snapshots every 500 iters; final at endTime

purgeWrite      3;      // keep only the last 3 time dirs + 0/ to save disk

writeFormat     ascii;

writePrecision  8;

writeCompression off;

timeFormat      general;

timePrecision   8;

runTimeModifiable yes;

functions
{
    // Per-iteration residuals → postProcessing/residuals/
    // Plot live with:  foamMonitor -l postProcessing/residuals/0/residuals.dat
    residuals
    {
        type            residuals;
        libs            ("libutilityFunctionObjects.so");
        writeControl    timeStep;
        writeInterval   1;
        fields          (U p k omega);
    }

    // Detailed solver info (initial + final residual, iterations per field)
    solverInfo
    {
        type            solverInfo;
        libs            ("libutilityFunctionObjects.so");
        writeControl    timeStep;
        writeInterval   1;
        fields          (U p k omega);
    }

    // Sanity check: velocity and pressure bounds each iteration
    fieldMinMax
    {
        type            fieldMinMax;
        libs            ("libfieldFunctionObjects.so");
        writeControl    timeStep;
        writeInterval   50;
        fields          (U p);
    }
}

