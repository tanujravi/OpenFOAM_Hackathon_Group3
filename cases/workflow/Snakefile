# ===========================================================================
#  Snakefile -- 24-hour QUASI-STEADY mobility-scenario sweep
# ===========================================================================
#  carve_mesh (once) -> flow_hour[h] (24) -> disp[h,scenario,pollutant]
#    (24 x 4 x 2 = 192) -> aggregate (daily mean/peak + % vs reference).
#
#  Each hour's frozen flow is reused across all scenarios + pollutants, so only
#  the emission scaling changes between scenarios (S1 x0.8, S2 x0.6, S3 tiered).
#  Each hour's scalar is solved to STEADY state independently (no carryover);
#  for hour-to-hour accumulation use the transient strategy (Snakefile.transient).
#
#  RUN (from cases/workflow/):
#     snakemake -n --cores 1                 # dry run: print the job plan
#     snakemake --cores 4                    # local; each solve uses NPROCS ranks
#  See workflow/README.md for SLURM usage and the python_bin caveat.
# ===========================================================================
import os
configfile: "config.yaml"

FLOW    = os.path.abspath(config["flow_case"])
DISP    = os.path.abspath(config["disp_case"])
TOOLS   = os.path.abspath(config["tools"])
WORK    = os.path.abspath(config["work_dir"])
RES     = os.path.abspath(config["results_dir"])
SCRIPTS = os.path.abspath("scripts")
PY      = config.get("python_bin", "python3")

HOURS = [str(h) for h in config["hours"]]
SCEN  = list(config["scenarios"])
POLL  = list(config["pollutants"])
NP    = int(config["nprocs"]); DT = config["DT"]; HALF = config["halfwidth"]
IT2   = int(config.get("flow_2ndorder_iters", 2000))
PAR   = "true" if config.get("parallel", True) else "false"

wildcard_constraints:
    hour = r"\d+", scenario = r"[A-Za-z0-9]+", pollutant = r"[A-Za-z0-9]+"

rule all:
    input:
        os.path.join(RES, "scenario_comparison.csv"),
        os.path.join(RES, "receptor_daily_summary.csv"),
        os.path.join(RES, "hourly_long.csv")

include: "rules/common.smk"

rule disp:
    input:
        os.path.join(WORK, "flow", "h{hour}", "frozen", "U")
    output:
        os.path.join(WORK, "disp", "h{hour}", "{scenario}", "{pollutant}", "receptors.csv")
    threads: NP
    shell:
        r'bash "{SCRIPTS}/run_disp.sh" {wildcards.hour} {wildcards.scenario} {wildcards.pollutant} '
        r'"{FLOW}" "{DISP}" "{TOOLS}" "{WORK}" {NP} {PAR} {DT} "{PY}"'

def all_receptor_csvs(_):
    return [os.path.join(WORK, "disp", "h%s" % h, s, p, "receptors.csv")
            for h in HOURS for s in SCEN for p in POLL]

rule aggregate:
    input: all_receptor_csvs
    output:
        os.path.join(RES, "scenario_comparison.csv"),
        os.path.join(RES, "receptor_daily_summary.csv"),
        os.path.join(RES, "hourly_long.csv")
    shell:
        r'"{PY}" "{TOOLS}/aggregate_day.py" --work "{WORK}" --out "{RES}"'

rule clean:
    shell: r'rm -rf "{WORK}" "{RES}" .snakemake'
